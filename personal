      setTimeout(()=>{const el=document.getElementById(id);if(el){el.style.opacity='1';el.style.transform='translateY(0)';el.style.transition='all .6s ease';}},i*320);
    }),300);
  },
  function(){}, // s12
];

function next(){if(cur<N-1)goTo(cur+1);}
function prev(){if(cur>0)goTo(cur-1);}
function togglePlay(){playing=!playing;document.getElementById('pbtn').textContent=playing?'⏸':'▶';
  if(playing)goTo(cur);else clr();}
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key===' '){e.preventDefault();next();}
  else if(e.key==='ArrowLeft'){e.preventDefault();prev();}
});
document.getElementById('discSlider').addEventListener('input',function(){
  document.getElementById('discVal').textContent=this.value+'%';
});
goTo(0);
</script>
