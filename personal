<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>NightSeam™ — The Personal Story · 12 Slides</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=Nunito:wght@300;400;600;700;800;900&family=DM+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --coral:#FF5A5F; --coral-d:#C83A3F; --coral-l:#FFF0F0;
  --teal:#00A699; --teal-l:#E6F7F6; --teal-d:#007A72;
  --gold:#F5A623; --gold-l:#FFD060; --gold-d:#A66D00;
  --navy:#0D1B2A; --blue:#0071C2; --blue-l:#E8F1FB;
  --ink:#222222; --mid:#6B7280; --light:#9CA3AF; --faint:#E5E7EB;
  --white:#FFFFFF; --off:#FAFAF9; --bg:#F5F4F0;
  --green:#008234; --green-l:#E8F5ED;
  --red:#CC0000; --red-l:#FCE8E8;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;
  font-family:'Nunito',sans-serif;color:var(--ink);background:var(--bg)}

/* ── SLIDE ENGINE ───────────────────────────── */
.slide{position:fixed;inset:0 0 52px 0;z-index:10;opacity:0;
  pointer-events:none;transition:opacity .42s cubic-bezier(.4,0,.2,1);
  overflow:hidden;display:flex;flex-direction:column}
.slide.active{opacity:1;pointer-events:all}
#flash{position:fixed;inset:0;z-index:900;background:var(--white);
  opacity:0;pointer-events:none;transition:opacity .07s}

/* ── ANIMATIONS ─────────────────────────────── */
@keyframes rU{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes rR{from{opacity:0;transform:translateX(-28px)}to{opacity:1;transform:translateX(0)}}
@keyframes rL{from{opacity:0;transform:translateX(28px)}to{opacity:1;transform:translateX(0)}}
@keyframes fI{from{opacity:0}to{opacity:1}}
@keyframes scIn{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
@keyframes popIn{0%{opacity:0;transform:scale(.8) translateY(30px)}
  70%{transform:scale(1.03) translateY(-4px)}100%{opacity:1;transform:scale(1) translateY(0)}}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(0,166,153,.4)}
  50%{box-shadow:0 0 0 8px rgba(0,166,153,.0)}}
@keyframes scanLine{from{left:-3px}to{left:calc(100% + 3px)}}
@keyframes typeCursor{0%,100%{opacity:1}50%{opacity:0}}
@keyframes countUp{from{opacity:0;filter:blur(4px);transform:scale(1.3)}
  to{opacity:1;filter:blur(0);transform:scale(1)}}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes shimmer{0%,100%{background-position:0%}50%{background-position:100%}}

/* ── TYPOGRAPHY ─────────────────────────────── */
.serif{font-family:'Playfair Display',serif}
.mono{font-family:'DM Mono',monospace}
.tag{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:4px;
  text-transform:uppercase;color:var(--light);display:block;margin-bottom:18px}
.h-cover{font-family:'Playfair Display',serif;font-size:clamp(50px,6.5vw,80px);
  font-weight:900;letter-spacing:-2px;line-height:.9;color:var(--ink)}
.h-lg{font-family:'Playfair Display',serif;font-size:clamp(36px,4.5vw,56px);
  font-weight:900;letter-spacing:-1.5px;line-height:.95;color:var(--ink)}
.h-md{font-family:'Playfair Display',serif;font-size:clamp(26px,3.2vw,40px);
  font-weight:700;letter-spacing:-1px;line-height:1;color:var(--ink)}
.em{color:var(--coral)}.em-t{color:var(--teal)}.em-g{color:var(--gold-d)}
.body{font-size:15px;line-height:1.72;color:var(--mid);font-weight:400}
.body strong{color:var(--ink);font-weight:700}

/* ── LAYOUT ─────────────────────────────────── */
.split{display:grid;grid-template-columns:1fr 1fr;height:100%}
.half-l{padding:64px 56px;display:flex;flex-direction:column;justify-content:center;gap:18px;border-right:1px solid var(--faint)}
.half-r{padding:48px 56px;display:flex;flex-direction:column;justify-content:center;gap:16px}
.center{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:48px 72px;gap:22px;text-align:center}
.cork{width:4px;height:40px;background:var(--coral);margin-bottom:8px}
.cork-t{width:4px;height:40px;background:var(--teal);margin-bottom:8px}

/* ── ADMIN PANEL MOCKUP ─────────────────────── */
.admin-panel{
  background:var(--white);border:1px solid var(--faint);
  border-radius:8px;overflow:hidden;
  box-shadow:0 8px 40px rgba(0,0,0,.1);
  width:100%;
}
.admin-topbar{
  background:var(--navy);height:42px;padding:0 18px;
  display:flex;align-items:center;gap:10px;
}
.admin-logo{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--white)}
.admin-dot{width:8px;height:8px;border-radius:50%}
.admin-tabs{background:#fff;border-bottom:1px solid var(--faint);
  display:flex;padding:0 18px;gap:2px}
.admin-tab{font-size:11px;font-weight:700;color:var(--light);
  padding:0 12px;height:36px;display:flex;align-items:center;
  border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap}
.admin-tab.on{color:var(--blue);border-bottom-color:var(--blue)}
.admin-body{padding:16px 18px;background:var(--off)}
.admin-section{background:#fff;border:1px solid var(--faint);margin-bottom:10px;overflow:hidden}
.admin-sec-head{padding:10px 14px;border-bottom:1px solid var(--faint);
  background:#fafafa;font-size:12px;font-weight:700;color:var(--ink);
  display:flex;align-items:center;justify-content:space-between}
.admin-row{padding:10px 14px;display:flex;align-items:center;gap:12px;
  border-bottom:1px solid var(--faint);font-size:12px}
.admin-row:last-child{border-bottom:none}
.admin-lbl{flex:1;color:var(--mid)}
.admin-lbl strong{color:var(--ink);display:block;font-size:12px;margin-bottom:1px}

/* ── TOGGLE ─────────────────────────────────── */
.tog{width:40px;height:22px;border-radius:11px;position:relative;
  cursor:pointer;transition:background .3s;flex-shrink:0}
.tog.off{background:var(--faint)}
.tog.on{background:var(--teal);box-shadow:0 0 0 3px rgba(0,166,153,.15);
  animation:pulse 2s ease infinite}
.tog-k{position:absolute;top:2px;width:18px;height:18px;border-radius:50%;
  background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.2);
  transition:left .3s cubic-bezier(.34,1.56,.64,1)}
.tog.off .tog-k{left:2px}
.tog.on .tog-k{left:20px}

/* ── GUEST POPUP MOCKUP ─────────────────────── */
.popup-shell{
  background:rgba(0,0,0,.52);display:flex;align-items:center;
  justify-content:center;padding:20px;width:100%;
  border-radius:6px;overflow:hidden;
}
.popup-card{
  background:#fff;border-radius:8px;overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,.3);
  width:100%;max-width:440px;
}
.popup-header{
  background:linear-gradient(135deg,var(--navy) 0%,#1a3050 100%);
  padding:16px 20px;display:flex;align-items:flex-start;gap:12px;
}
.popup-icon-wrap{
  width:40px;height:40px;border-radius:8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:20px;
  background:rgba(255,255,255,.12);
}
.popup-h-title{font-size:15px;font-weight:800;color:#fff;margin-bottom:2px}
.popup-h-sub{font-size:11px;color:rgba(255,255,255,.55)}
.popup-badge{
  margin-left:auto;padding:3px 10px;border-radius:10px;
  background:var(--gold);color:var(--navy);
  font-size:10px;font-weight:800;flex-shrink:0;align-self:flex-start;margin-top:2px}
.popup-body{padding:16px 20px}
.popup-highlight{
  background:var(--green-l);border-left:3px solid var(--green);
  padding:8px 12px;margin-bottom:12px;font-size:12px;
  display:flex;align-items:flex-start;gap:8px;
}
.popup-checks{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.popup-check{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--mid)}
.popup-check .ck{color:var(--teal);font-size:14px;font-weight:900;flex-shrink:0}
.popup-main{font-size:13px;color:var(--ink);line-height:1.65;margin-bottom:14px;font-weight:600}
.popup-main .save{
  background:linear-gradient(90deg,var(--gold-d),var(--gold-l),var(--gold-d));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;background-size:200%;font-weight:900;font-size:18px;
  animation:shimmer 2s ease infinite}
.popup-cta-row{display:grid;grid-template-columns:1.4fr 1fr;gap:8px}
.btn-accept{
  background:var(--teal);color:#fff;border:none;padding:11px 14px;
  font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;
  cursor:pointer;border-radius:5px;display:flex;align-items:center;gap:5px;
  justify-content:center;transition:background .2s;
}
.btn-accept:hover{background:var(--teal-d)}
.btn-decline{
  background:#fff;color:var(--light);border:1px solid var(--faint);
  padding:11px 14px;font-family:'Nunito',sans-serif;font-size:12px;
  font-weight:600;cursor:pointer;border-radius:5px;text-align:center;
  transition:all .2s;
}
.btn-decline:hover{border-color:var(--red);color:var(--red)}
.popup-footer{
  padding:8px 20px;background:var(--off);border-top:1px solid var(--faint);
  font-size:10px;color:var(--light);display:flex;align-items:center;gap:6px}

/* ── BOOKING CONFIRMATION ────────────────────── */
.conf{background:#fff;border:1px solid var(--faint);border-radius:8px;overflow:hidden;
  box-shadow:0 4px 24px rgba(0,0,0,.08)}
.conf-head{background:var(--teal);padding:14px 20px;color:#fff}
.conf-head-t{font-size:15px;font-weight:800}
.conf-head-s{font-size:10px;color:rgba(255,255,255,.7);margin-top:2px;
  font-family:'DM Mono',monospace;letter-spacing:.5px}
.conf-body{padding:14px 20px}
.conf-seg{border-left:4px solid;padding:10px 14px;margin-bottom:8px;
  display:flex;justify-content:space-between;align-items:flex-start}
.conf-seg-a{border-color:var(--teal);background:var(--teal-l)}
.conf-seg-b{border-color:var(--gold-d);background:#FFF9EE}
.conf-room{font-size:13px;font-weight:700;color:var(--ink)}
.conf-dates{font-family:'DM Mono',monospace;font-size:10px;color:var(--mid);margin-top:3px}
.conf-price{font-family:'Playfair Display',serif;font-size:18px;font-weight:900;color:var(--navy)}
.conf-seam{text-align:center;font-size:10px;color:var(--light);padding:4px;
  font-family:'DM Mono',monospace;letter-spacing:1px}
.conf-total{padding:10px 14px;background:var(--navy);display:flex;
  justify-content:space-between;align-items:center}
.conf-total-l{font-size:13px;color:rgba(255,255,255,.7)}
.conf-total-v{font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:var(--gold-l)}
.conf-badge{display:inline-block;padding:2px 8px;border-radius:10px;
  font-size:10px;font-weight:700;margin-top:5px}
.cb-red{background:var(--red-l);color:var(--red);border:1px solid rgba(204,0,0,.18)}
.cb-teal{background:var(--teal-l);color:var(--teal-d);border:1px solid rgba(0,166,153,.22)}

/* ── CODE BLOCK ─────────────────────────────── */
.code{background:#0D1B2A;border-radius:6px;overflow:hidden;
  font-family:'DM Mono',monospace;font-size:11.5px;line-height:1.8}
.code-bar{background:#162232;padding:7px 14px;display:flex;align-items:center;gap:7px;
  border-bottom:1px solid rgba(255,255,255,.06)}
.cd{width:9px;height:9px;border-radius:50%}
.cf{font-size:9.5px;color:rgba(255,255,255,.3);margin-left:8px}
.code-body{padding:14px 18px;color:#A8B9CC}
.ck{color:#C792EA}.cv{color:#FF6B8A}.cs{color:#A8E478}.cf2{color:#82AAFF}
.cm{color:#89DDFF}.cc{color:#4A5E74;font-style:italic}.cn{color:#F5A623}
.code-line{opacity:0;transition:opacity .25s;display:block}
.code-line.show{opacity:1}
.highlight-line{background:rgba(0,166,153,.15);border-left:3px solid var(--teal);
  padding:4px 10px;margin:8px -18px;display:block;opacity:0;transition:opacity .5s}
.highlight-line.show{opacity:1}

/* ── STAT STRIP ─────────────────────────────── */
.stats-strip{display:flex;gap:0;border:1px solid var(--faint)}
.ss-cell{flex:1;padding:18px 14px;text-align:center;border-right:1px solid var(--faint)}
.ss-cell:last-child{border-right:none}
.ss-v{font-family:'Playfair Display',serif;font-size:clamp(24px,3vw,36px);
  font-weight:900;line-height:1;letter-spacing:-1px}
.ss-l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;
  text-transform:uppercase;color:var(--light);margin-top:6px}

/* ── THREE STATEMENTS ────────────────────────── */
.stmt{display:flex;align-items:flex-start;gap:20px;
  padding:24px 0;border-bottom:1px solid var(--faint);
  opacity:0;transform:translateY(16px);transition:all .5s ease}
.stmt:last-child{border-bottom:none}
.stmt.show{opacity:1;transform:translateY(0)}
.stmt-ic{width:44px;height:44px;border-radius:50%;display:flex;
  align-items:center;justify-content:center;font-size:20px;flex-shrink:0;margin-top:2px}
.ic-coral{background:var(--coral-l)}.ic-teal{background:var(--teal-l)}.ic-gold{background:#FFF9EE}
.stmt-h{font-size:clamp(17px,2.2vw,24px);font-weight:800;
  letter-spacing:-.3px;line-height:1.2;color:var(--ink)}
.stmt-h .kw{color:var(--coral)}
.stmt-h .kwt{color:var(--teal)}
.stmt-s{font-size:13px;color:var(--mid);margin-top:5px;line-height:1.6}

/* ── CHART ───────────────────────────────────── */
.chart{width:100%;border-collapse:collapse;border:1px solid var(--faint);background:#fff}
.chart th{background:var(--off);font-size:10px;font-weight:700;color:var(--light);
  text-align:center;padding:7px 4px;border-bottom:2px solid var(--faint);
  border-right:1px solid var(--faint)}
.chart th:first-child{text-align:left;padding-left:14px;min-width:110px}
.chart td{border-right:1px solid var(--faint);border-bottom:1px solid var(--faint);padding:0}
.chart td:first-child{padding:8px 14px;font-weight:700;font-size:12px;
  color:var(--ink);background:var(--off)}
.cc-cell{width:100%;height:40px;display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;transition:all .38s ease}
.c-e{background:#fff;color:var(--faint)}
.c-g{background:#F0FFF8;color:var(--teal)}
.c-r{background:#FFF5F5;color:var(--coral)}
.c-m{background:#FFFBF0;color:var(--gold-d);border:1px solid rgba(245,166,35,.2)}
.chart-scan{position:absolute;top:0;bottom:0;width:2px;z-index:10;
  background:linear-gradient(180deg,transparent,var(--teal),var(--gold-l),var(--teal),transparent);
  box-shadow:0 0 10px rgba(0,166,153,.5);opacity:0;left:0}
.chart-scan.on{opacity:1}

/* ── PERSONAL QUOTE ──────────────────────────── */
.p-quote{
  font-family:'Playfair Display',serif;
  font-size:clamp(18px,2.4vw,28px);font-weight:400;
  font-style:italic;color:var(--mid);line-height:1.55;
  padding:24px 32px;border-left:4px solid var(--coral);
  background:var(--coral-l);
  opacity:0;animation:rR .7s ease both;
}
.p-quote strong{color:var(--ink);font-style:normal;font-weight:800}

/* ── CONTROLS ────────────────────────────────── */
.ctrl{position:fixed;bottom:0;left:0;right:0;height:52px;z-index:800;
  background:#fff;border-top:1px solid var(--faint);
  display:flex;align-items:center;padding:0 24px;gap:10px}
.dots{display:flex;gap:5px}
.dot{width:6px;height:6px;border-radius:50%;background:var(--faint);
  cursor:pointer;transition:all .25s}
.dot.on{background:var(--coral);transform:scale(1.6)}
.dot.done{background:var(--light)}
.pb{flex:1;height:2px;background:var(--faint)}
.pb-f{height:100%;background:var(--coral);transition:width .15s linear}
.cbtn{font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;
  padding:6px 18px;border:1px solid var(--faint);background:#fff;
  color:var(--mid);cursor:pointer;letter-spacing:.3px;transition:all .2s}
.cbtn:hover{border-color:var(--coral);color:var(--coral)}
.clbl{font-family:'DM Mono',monospace;font-size:9px;color:var(--light);white-space:nowrap}
.wm{position:absolute;bottom:58px;right:14px;font-family:'DM Mono',monospace;
  font-size:8px;color:var(--faint);letter-spacing:1px;z-index:5}
</style>
</head>
<body>
<div id="flash"></div>

<!-- ╔══════════════════════════════════
     SLIDE 01 · THE PERSONAL ORIGIN
     ══════════════════════════════════ -->
<div class="slide" id="s1" style="background:#fff">
  <div class="split">
    <div class="half-l" style="background:var(--navy);border-right:none">
      <div style="animation:rR .7s ease .2s both;opacity:0">
        <span class="tag" style="color:rgba(255,255,255,.3)">The Origin · Why This Exists</span>
        <div style="width:4px;height:48px;background:var(--coral);margin-bottom:20px"></div>
        <h1 class="h-cover" style="color:#fff;margin-bottom:20px">
          I saw revenue<br>expire every<br><span style="color:var(--gold-l)">midnight.</span>
        </h1>
        <p style="font-size:15px;color:rgba(255,255,255,.6);line-height:1.75;max-width:360px;margin-bottom:28px">
          I ran a hotel. Every night I watched the booking chart — Twin Room free three days, Double Room free six days, guest needs nine nights — and the system said <strong style="color:rgba(255,255,255,.85)">"Unavailable."</strong> The room expired. The revenue was gone. I couldn't stop thinking about it.
        </p>
        <!-- Personal decision point -->
        <div style="border:1px solid rgba(255,255,255,.12);padding:16px 18px;background:rgba(255,255,255,.04)">
          <div style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:2px;
            color:rgba(255,255,255,.3);text-transform:uppercase;margin-bottom:8px">The decision</div>
          <div style="font-size:14px;color:rgba(255,255,255,.75);line-height:1.65;font-style:italic;font-family:'Playfair Display',serif">
            "I spent my own money. I bought a booking engine. I learned to code. I modified the system myself — alone — until the algorithm worked."
          </div>
          <div style="font-family:'DM Mono',monospace;font-size:9px;color:rgba(255,255,255,.25);margin-top:8px">
            — Ayman, Founder · NightSeam™ · 2016
          </div>
        </div>
      </div>
    </div>
    <div class="half-r" style="background:var(--off)">
      <div style="animation:rL .7s ease .4s both;opacity:0">
        <span class="tag">What I built — with my own hands</span>
        <!-- Timeline of personal investment -->
        <div style="display:flex;flex-direction:column;gap:0">
          <div style="display:flex;gap:16px;padding:18px 0;border-bottom:1px solid var(--faint)">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--coral-l);
              display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">💡</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--ink)">Identified the gap</div>
              <div style="font-size:12px;color:var(--mid);margin-top:3px">Watched partial availability expire nightly. Knew there had to be a way to connect the two halves.</div>
            </div>
          </div>
          <div style="display:flex;gap:16px;padding:18px 0;border-bottom:1px solid var(--faint)">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--coral-l);
              display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">💸</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--ink)">Spent personal funds</div>
              <div style="font-size:12px;color:var(--mid);margin-top:3px">Purchased a professional hotel booking engine. My own investment. My own risk.</div>
            </div>
          </div>
          <div style="display:flex;gap:16px;padding:18px 0;border-bottom:1px solid var(--faint)">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--teal-l);
              display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">📚</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--ink)">Learned to code</div>
              <div style="font-size:12px;color:var(--mid);margin-top:3px">Studied PHP, JavaScript, database queries — specifically to write this one algorithm.</div>
            </div>
          </div>
          <div style="display:flex;gap:16px;padding:18px 0;border-bottom:1px solid var(--faint)">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--teal-l);
              display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">⚙️</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--ink)">Modified the system</div>
              <div style="font-size:12px;color:var(--mid);margin-top:3px">Wrote the Room Relocation and Hotel Relocation modules. Added the admin toggle. Built the guest popup.</div>
            </div>
